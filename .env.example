# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.

# Secret used to sign the short-lived download cookie. Use a long random string.
#   generate with:  openssl rand -base64 32
OTP_SECRET=change-me-to-a-long-random-string

# Google Apps Script Web App URL that appends each submission to your Sheet.
# (Create it: Sheet → Extensions → Apps Script → deploy as Web app → "Anyone".)
# Ends in /exec
GOOGLE_SHEET_WEBHOOK=

# The file link the download button serves — a GitHub Release asset URL, e.g.
# https://github.com/<user>/mochi-site/releases/download/v0.1.0/Mochi-0.1.0-arm64.dmg
DOWNLOAD_URL=
