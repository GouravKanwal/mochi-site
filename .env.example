# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.

# Secret used to sign the one-time-code cookies. Use a long random string.
#   generate with:  openssl rand -base64 32
OTP_SECRET=change-me-to-a-long-random-string

# Resend API key (https://resend.com → API Keys). Used to send the email codes.
RESEND_API_KEY=

# The "From" address. For real delivery you must verify a domain in Resend,
# then use something like: Cat AI <noreply@yourdomain.com>
# For quick testing Resend allows: onboarding@resend.dev (only sends to your own account email)
EMAIL_FROM=Cat AI <onboarding@resend.dev>

# Where new-download notifications (the captured name + email) are sent.
OWNER_EMAIL=you@example.com

# The actual file link revealed after verification — a GitHub Release asset URL, e.g.
# https://github.com/<user>/catai-site/releases/download/v0.1.0/Cat-AI-0.1.0-arm64.dmg
DOWNLOAD_URL=
